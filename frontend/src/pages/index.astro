---
import Layout from "../layouts/Layout.astro"
---

<Layout>
	<div class="min-h-[100dvh] flex flex-col bg-background">
		<!-- Header -->
		<header class="py-4 px-6">
			<div class="max-w-4xl mx-auto flex items-center justify-between">
				<a
					href="/"
					class="text-foreground text-2xl font-bold tracking-tight"
				>
					Votomatic
				</a>
				<nav class="hidden md:flex items-center gap-6">
					<a
						href="/como-funciona"
						class="text-foreground-secondary hover:text-foreground transition-colors text-sm"
					>
						Cómo funciona
					</a>
					<a
						href="/preguntas-frecuentes"
						class="text-foreground-secondary hover:text-foreground transition-colors text-sm"
					>
						Preguntas frecuentes
					</a>
					<a
						href="/documentacion"
						class="text-foreground-secondary hover:text-foreground transition-colors text-sm"
					>
						Documentación
					</a>
				</nav>
				<button
					id="mobile-menu-button"
					class="md:hidden p-2 text-foreground"
				>
					<svg
						class="w-6 h-6"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
			</div>
			<!-- Mobile menu -->
			<div
				id="mobile-menu"
				class="hidden md:hidden max-w-4xl mx-auto pt-4 pb-2"
			>
				<a
					href="/como-funciona"
					class="block py-2 text-foreground-secondary hover:text-foreground transition-colors"
				>
					Cómo funciona
				</a>
				<a
					href="/preguntas-frecuentes"
					class="block py-2 text-foreground-secondary hover:text-foreground transition-colors"
				>
					Preguntas frecuentes
				</a>
				<a
					href="/documentacion"
					class="block py-2 text-foreground-secondary hover:text-foreground transition-colors"
				>
					Documentación
				</a>
			</div>
		</header>

		<!-- Main Content -->
		<main
			class="flex-1 flex flex-col items-center justify-center px-6 py-12"
		>
			<div class="max-w-2xl mx-auto text-center">
				<!-- Logo/Title Area -->
				<div class="mb-8">
					<h1
						class="text-4xl md:text-5xl lg:text-6xl font-bold text-foreground mb-4 leading-tight"
					>
						Conoce tu orientación política
					</h1>
					<p
						class="text-lg md:text-xl text-foreground-secondary leading-relaxed"
					>
						Descubre qué partidos políticos están más alineados con
						tus opiniones
					</p>
				</div>

				<!-- Info Card -->
				<div class="bg-surface rounded-2xl p-6 md:p-8 mb-8 text-left">
					<p class="text-foreground leading-relaxed">
						Se ha analizado los planes de gobierno de los <strong
							class="text-accent">37 partidos</strong
						> que participan en las elecciones. Ahora es tu turno: compara
						tus opiniones con las de los partidos.
					</p>
					<p class="text-foreground-secondary text-sm mt-4">
						Votomatic no es una recomendación de voto, sino un
						recurso informativo sobre elecciones y política.
					</p>
				</div>

				<!-- CTA Button -->
				<a
					href="/elecciones-generales-2026"
					class="inline-flex items-center justify-center gap-3 bg-primary hover:brightness-95 text-primary-foreground font-bold text-lg px-8 py-4 rounded-full transition-all duration-200 shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98]"
				>
					<span>Empezar</span>
					<svg
						class="w-5 h-5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M5 12h14M12 5l7 7-7 7"></path>
					</svg>
				</a>
			</div>
		</main>

		<!-- Footer -->
		<footer class="py-6 px-6">
			<div
				class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-center gap-4 text-foreground-secondary text-sm"
			>
				<p>Elecciones Generales 2026 · Perú</p>
			</div>
		</footer>
	</div>
</Layout>

<script>
	const button = document.getElementById("mobile-menu-button")
	const menu = document.getElementById("mobile-menu")
	button?.addEventListener("click", () => {
		menu?.classList.toggle("hidden")
	})
</script>
